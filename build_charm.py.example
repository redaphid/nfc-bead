"""
Wooli Charm Builder — parameterized for easy tweaking.

Edit the CONFIG section below, then run:
    blender --background --python build_charm.py
Or execute via Blender MCP / Python console.

Tested with Blender 5.0.1.
"""
import bpy
import bmesh
import math
from mathutils import Vector

# ═══════════════════════════════════════════════════════════
# CONFIG — edit these to adjust the charm
# ═══════════════════════════════════════════════════════════

SVG_PATH = r"./silhouette.svg"     # path to your input SVG (absolute or relative)
OUTPUT_DIR = r"./out"              # where STLs and .blend get written

TARGET_WIDTH = 25.0       # mm — overall width
THICKNESS = 5.0           # mm — total (split into 2 x 2.5mm halves)

# String hole
HOLE_DIAMETER = 2.0       # mm
HOLE_Y = 7.09             # mm — Y position through head (along X axis)
HOLE_Z_OFFSET = 0.0       # mm — offset of hole center from the bead's Z midplane.
                          # 0 (default) puts the hole *on* the split plane → each
                          # half hosts an open half-circle groove on its inner face.
                          # Setting this to (THICKNESS/4) shifts the hole entirely
                          # into one half so the inner face is solid at y=HOLE_Y
                          # (better first-layer adhesion) and the tube becomes a
                          # small interior cavity bridged twice by the slicer.
                          # Sign: positive → into Top, negative → into Bottom.
# Picking HOLE_Y: see prompts/nfc-bead/prompt.md "String-hole placement rules".
# Need ≥ 2.5 mm of solid silhouette above the hole, on a *wide* band — not on
# a narrow ear-flap, hair-ridge, or tip. Drop into the forehead/head body if
# the natural top is too narrow.

# NFC pocket (bottom half only)
NFC_DIAMETER = 10.5       # mm
NFC_DEPTH = 0.8           # mm
NFC_POS = (0.0, -1.0)    # (X, Y) center

# Pegs — friction fit
PEG_DIAMETER = 2.0        # mm (was 1.5 — bigger for strength)
PEG_HEIGHT = 1.5          # mm
PEG_CLEARANCE = 0.1       # mm gap per side for peg holes

# Peg positions (X, Y) — adjust these freely
PEGS = [
    (-3.5, 4.5),    # near head — moved down from 6.0 to clear string hole
    (7.0, -3.0),    # back/center — good margin
    (4.5, -6.0),    # bottom — moved inward to clear silhouette edge + NFC
]

# Trunk gap fill region (boundary edges to select and fill)
TRUNK_GAP_X = (-5.0, -2.0)
TRUNK_GAP_Y = (-1.0, 1.0)

# ═══════════════════════════════════════════════════════════
# BUILD — don't edit below unless changing the pipeline
# ═══════════════════════════════════════════════════════════

import os
OUTPUT_BOTTOM = os.path.join(OUTPUT_DIR, "wooli_charm_bottom.stl")
OUTPUT_TOP = os.path.join(OUTPUT_DIR, "wooli_charm_top.stl")
OUTPUT_BLEND = os.path.join(OUTPUT_DIR, "wooli_charm_pegs.blend")

def clean_mesh(obj, threshold=0.005):
    """Remove doubles and fix normals."""
    obj.select_set(True)
    bpy.context.view_layer.objects.active = obj
    bpy.ops.object.mode_set(mode='EDIT')
    bpy.ops.mesh.select_all(action='SELECT')
    bpy.ops.mesh.remove_doubles(threshold=threshold)
    bpy.ops.mesh.normals_make_consistent(inside=False)
    bpy.ops.object.mode_set(mode='OBJECT')

def boolean_op(target, cutter, operation='DIFFERENCE', name="Bool"):
    """Apply boolean modifier and delete cutter."""
    bpy.context.view_layer.objects.active = target
    target.select_set(True)
    b = target.modifiers.new(name=name, type='BOOLEAN')
    b.operation = operation
    b.object = cutter
    b.solver = 'EXACT'
    bpy.ops.object.modifier_apply(modifier=name)
    bpy.ops.object.select_all(action='DESELECT')
    cutter.select_set(True)
    bpy.ops.object.delete()

def check_nonmanifold(obj):
    """Return count of non-manifold edges."""
    obj.select_set(True)
    bpy.context.view_layer.objects.active = obj
    bpy.ops.object.mode_set(mode='EDIT')
    bpy.ops.mesh.select_all(action='DESELECT')
    bpy.ops.mesh.select_non_manifold()
    bm = bmesh.from_edit_mesh(obj.data)
    nm = sum(1 for e in bm.edges if e.select)
    bpy.ops.object.mode_set(mode='OBJECT')
    return nm

def verify_hole(obj, origin, direction, label=""):
    """Raycast to check if a hole is open."""
    depsgraph = bpy.context.evaluated_depsgraph_get()
    eval_obj = obj.evaluated_get(depsgraph)
    result = eval_obj.ray_cast(origin, direction)
    status = "OPEN" if not result[0] else f"hit z={result[1].z:.3f}"
    print(f"  {label}: {status}")
    return not result[0]

print("=" * 60)
print("Wooli Charm Build")
print("=" * 60)

# ── Step 1: Clear scene, import SVG ───────────────────────
bpy.ops.object.select_all(action='SELECT')
bpy.ops.object.delete()
for c in list(bpy.data.collections):
    if c.name != 'Scene Collection':
        bpy.data.collections.remove(c)

bpy.ops.import_curve.svg(filepath=SVG_PATH)
curves = [obj for obj in bpy.context.scene.objects if obj.type == 'CURVE']
print(f"Imported {len(curves)} curve(s)")

bpy.ops.object.select_all(action='DESELECT')
for obj in curves:
    obj.select_set(True)
bpy.context.view_layer.objects.active = curves[0]
if len(curves) > 1:
    bpy.ops.object.join()

curve_obj = bpy.context.active_object
curve_obj.data.dimensions = '2D'
curve_obj.data.fill_mode = 'BOTH'
curve_obj.data.resolution_u = 64

# ── Step 2: Convert to mesh, scale ────────────────────────
bpy.ops.object.convert(target='MESH')
mesh_obj = bpy.context.active_object

current_w = mesh_obj.dimensions.x
if current_w > 0:
    sf = (TARGET_WIDTH / 1000.0) / current_w
    mesh_obj.scale = (sf, sf, sf)
    bpy.ops.object.transform_apply(scale=True)

mesh_obj.scale = (1000, 1000, 1000)
bpy.ops.object.transform_apply(scale=True)
bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
mesh_obj.location = (0, 0, 0)

# Clean flat mesh
bpy.ops.object.mode_set(mode='EDIT')
bpy.ops.mesh.select_all(action='SELECT')
bpy.ops.mesh.remove_doubles(threshold=0.005)
bpy.ops.mesh.normals_make_consistent(inside=False)

# ── Step 3: Fill trunk gap ────────────────────────────────
bpy.ops.mesh.select_all(action='DESELECT')
bm = bmesh.from_edit_mesh(mesh_obj.data)
bm.edges.ensure_lookup_table()

trunk_count = 0
for e in bm.edges:
    if e.is_boundary:
        v0, v1 = e.verts
        if (TRUNK_GAP_X[0] <= v0.co.x <= TRUNK_GAP_X[1] and
            TRUNK_GAP_Y[0] <= v0.co.y <= TRUNK_GAP_Y[1] and
            TRUNK_GAP_X[0] <= v1.co.x <= TRUNK_GAP_X[1] and
            TRUNK_GAP_Y[0] <= v1.co.y <= TRUNK_GAP_Y[1]):
            e.select = True
            trunk_count += 1

bmesh.update_edit_mesh(mesh_obj.data)
print(f"Filling trunk gap ({trunk_count} edges)...")
bpy.ops.mesh.fill()

bpy.ops.mesh.select_all(action='SELECT')
bpy.ops.mesh.dissolve_limited(angle_limit=math.radians(0.5))
bpy.ops.mesh.normals_make_consistent(inside=False)

# ── Step 4: Extrude to thickness ──────────────────────────
bpy.ops.mesh.select_all(action='SELECT')
bpy.ops.mesh.extrude_region_move(
    TRANSFORM_OT_translate={"value": (0, 0, THICKNESS)}
)
bpy.ops.mesh.select_all(action='SELECT')
bpy.ops.mesh.remove_doubles(threshold=0.005)
bpy.ops.mesh.normals_make_consistent(inside=False)
bpy.ops.object.mode_set(mode='OBJECT')

bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
mesh_obj.location = (0, 0, 0)
dims = mesh_obj.dimensions
print(f"Extruded: {dims.x:.2f} x {dims.y:.2f} x {dims.z:.2f} mm")

# ── Step 5: String hole ──────────────────────────────────
# Drill at the mesh's actual Z midpoint, then shift by HOLE_Z_OFFSET. Computing
# z_mid from the live mesh (not from THICKNESS/2) is important because earlier
# pipeline steps may have left the mesh non-centered on z=0.
zs = [v.co.z for v in mesh_obj.data.vertices]
z_mid_live = (min(zs) + max(zs)) / 2.0
z_hole = z_mid_live + HOLE_Z_OFFSET
print(f"String hole: {HOLE_DIAMETER}mm at Y={HOLE_Y}, z={z_hole:.2f} (offset={HOLE_Z_OFFSET:+.2f})...")
bpy.ops.mesh.primitive_cylinder_add(
    vertices=48, radius=HOLE_DIAMETER / 2.0,
    depth=dims.x * 4, location=(0, HOLE_Y, z_hole),
    rotation=(0, math.radians(90), 0),
)
boolean_op(mesh_obj, bpy.context.active_object, 'DIFFERENCE', "Hole")
clean_mesh(mesh_obj)

bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
mesh_obj.location = (0, 0, 0)
mesh_obj.name = "FullBead"

z_min = min(v.co.z for v in mesh_obj.data.vertices)
z_max = max(v.co.z for v in mesh_obj.data.vertices)
z_mid = (z_min + z_max) / 2.0
print(f"Z: {z_min:.2f} to {z_max:.2f}, mid={z_mid:.2f}")

# ── Step 6: Verify peg positions ──────────────────────────
# Raycasts the peg CENTER plus 8 perimeter points to catch a peg whose center
# is inside the silhouette but whose edge pokes through the boundary (gotcha
# #21 in prompts/nfc-bead/prompt.md). Center-only checks miss this — the
# original recipe shipped with that bug for many revisions before it was
# caught visually on a printed bead.
print("\nPeg position check:")
depsgraph = bpy.context.evaluated_depsgraph_get()
eval_full = mesh_obj.evaluated_get(depsgraph)
nfc_r = NFC_DIAMETER / 2.0
peg_r = PEG_DIAMETER / 2.0
perim_offsets = [(peg_r * math.cos(k * math.pi / 4.0),
                  peg_r * math.sin(k * math.pi / 4.0)) for k in range(8)]
any_warn = False
for i, (px, py) in enumerate(PEGS):
    center_hit = eval_full.ray_cast(Vector((px, py, z_max+5)), Vector((0,0,-1)))[0]
    edge_misses = sum(1 for ox, oy in perim_offsets
                      if not eval_full.ray_cast(
                          Vector((px + ox, py + oy, z_max+5)),
                          Vector((0,0,-1)))[0])
    nfc_dist = math.sqrt((px - NFC_POS[0])**2 + (py - NFC_POS[1])**2)
    nfc_clear = nfc_dist - nfc_r - peg_r
    hole_dist = abs(py - HOLE_Y)
    edge_note = "" if edge_misses == 0 else f", EDGES_CLIPPING={edge_misses}/8"
    print(f"  Peg {i} ({px:+.1f}, {py:+.1f}): solid={center_hit}, "
          f"NFC clearance={nfc_clear:.1f}mm, hole dist={hole_dist:.1f}mm{edge_note}")
    if not center_hit:
        any_warn = True
        print(f"    WARNING: Peg {i} center is outside the silhouette!")
    if edge_misses > 0:
        any_warn = True
        print(f"    WARNING: Peg {i} edge pokes past the silhouette boundary "
              f"({edge_misses} of 8 perimeter points outside)")
    if nfc_clear < 0:
        any_warn = True
        print(f"    WARNING: Peg {i} overlaps NFC cavity!")
if any_warn:
    print("  → fix PEGS in CONFIG so every peg's center+perimeter sits inside the silhouette and clears NFC")

# ── Step 7: Split into halves ─────────────────────────────
box_size = 200

print("\n--- Bottom Half ---")
bpy.ops.object.select_all(action='DESELECT')
mesh_obj.select_set(True)
bpy.context.view_layer.objects.active = mesh_obj
bpy.ops.object.duplicate()
bottom = bpy.context.active_object
bottom.name = "Bottom"

bpy.ops.mesh.primitive_cube_add(size=1, location=(0, 0, z_min + (z_mid - z_min) / 2.0))
box = bpy.context.active_object
box.scale = (box_size, box_size, (z_mid - z_min))
bpy.ops.object.transform_apply(scale=True)
boolean_op(bottom, box, 'INTERSECT', "Cut")
clean_mesh(bottom, 0.01)
nm = check_nonmanifold(bottom)
print(f"Bottom non-manifold: {nm}")

print("\n--- Top Half ---")
bpy.ops.object.select_all(action='DESELECT')
mesh_obj.select_set(True)
bpy.context.view_layer.objects.active = mesh_obj
bpy.ops.object.duplicate()
top = bpy.context.active_object
top.name = "Top"

bpy.ops.mesh.primitive_cube_add(size=1, location=(0, 0, z_mid + (z_max - z_mid) / 2.0))
box = bpy.context.active_object
box.scale = (box_size, box_size, (z_max - z_mid))
bpy.ops.object.transform_apply(scale=True)
boolean_op(top, box, 'INTERSECT', "Cut")
clean_mesh(top, 0.01)
nm = check_nonmanifold(top)
print(f"Top non-manifold: {nm}")

# ── Step 8: NFC pocket on bottom ──────────────────────────
b_z_max = max(v.co.z for v in bottom.data.vertices)
nfc_cutter_depth = NFC_DEPTH * 2 + 0.1
print(f"\nNFC pocket: {NFC_DIAMETER}mm at {NFC_POS}...")
bpy.ops.mesh.primitive_cylinder_add(
    vertices=64, radius=NFC_DIAMETER / 2.0, depth=nfc_cutter_depth,
    location=(NFC_POS[0], NFC_POS[1], b_z_max - NFC_DEPTH + nfc_cutter_depth / 2.0),
)
boolean_op(bottom, bpy.context.active_object, 'DIFFERENCE', "NFC")
clean_mesh(bottom)

# ── Step 9: Peg holes on top (post-split) ─────────────────
t_z_min = min(v.co.z for v in top.data.vertices)
hole_r = (PEG_DIAMETER + PEG_CLEARANCE * 2) / 2.0
print(f"\nPeg holes on top (r={hole_r:.2f}mm)...")
for i, (px, py) in enumerate(PEGS):
    cutter_bottom = t_z_min - 1.0
    cutter_top = t_z_min + PEG_HEIGHT + 0.3
    cutter_depth = cutter_top - cutter_bottom
    cutter_z = (cutter_bottom + cutter_top) / 2.0
    bpy.ops.mesh.primitive_cylinder_add(
        vertices=32, radius=hole_r, depth=cutter_depth,
        location=(px, py, cutter_z),
    )
    boolean_op(top, bpy.context.active_object, 'DIFFERENCE', f"PH{i}")

clean_mesh(top)
nm = check_nonmanifold(top)
print(f"Top after peg holes non-manifold: {nm}")

# Verify peg holes are open
print("Verifying peg holes:")
for i, (px, py) in enumerate(PEGS):
    verify_hole(top, Vector((px, py, t_z_min - 2)), Vector((0, 0, 1)), f"Peg {i}")

# ── Step 10: Pegs on bottom (boolean UNION) ───────────────
b_z_max = max(v.co.z for v in bottom.data.vertices)
print(f"\nPegs on bottom (d={PEG_DIAMETER}mm, h={PEG_HEIGHT}mm)...")
for i, (px, py) in enumerate(PEGS):
    bpy.ops.mesh.primitive_cylinder_add(
        vertices=32, radius=PEG_DIAMETER / 2.0, depth=PEG_HEIGHT,
        location=(px, py, b_z_max + PEG_HEIGHT / 2.0),
    )
    boolean_op(bottom, bpy.context.active_object, 'UNION', f"Peg{i}")

clean_mesh(bottom)
nm = check_nonmanifold(bottom)
print(f"Bottom after pegs non-manifold: {nm}")

# ── Step 11: Position for printing ────────────────────────
mesh_obj.hide_set(True)
mesh_obj.hide_render = True

# Flip bottom
bpy.ops.object.select_all(action='DESELECT')
bottom.select_set(True)
bpy.context.view_layer.objects.active = bottom
bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
bottom.rotation_euler = (math.radians(180), 0, 0)
bpy.ops.object.transform_apply(rotation=True)
bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
bottom.location = (-18, 0, bottom.dimensions.z / 2.0)

# Position top
bpy.ops.object.select_all(action='DESELECT')
top.select_set(True)
bpy.context.view_layer.objects.active = top
bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
top.location = (18, 0, top.dimensions.z / 2.0)

# Materials + flat shading
for obj, color, name in [(bottom, (0.2, 0.6, 0.3, 1), "BottomMat"),
                          (top, (0.4, 0.1, 0.8, 1), "TopMat")]:
    mat = bpy.data.materials.new(name=name)
    mat.use_nodes = True
    bsdf = mat.node_tree.nodes["Principled BSDF"]
    bsdf.inputs["Base Color"].default_value = color
    bsdf.inputs["Roughness"].default_value = 0.4
    obj.data.materials.clear()
    obj.data.materials.append(mat)
    bpy.ops.object.select_all(action='DESELECT')
    obj.select_set(True)
    bpy.context.view_layer.objects.active = obj
    bpy.ops.object.shade_flat()

# ── Step 12: Export ───────────────────────────────────────
bpy.ops.object.select_all(action='DESELECT')
bottom.select_set(True)
bpy.context.view_layer.objects.active = bottom
bpy.ops.wm.stl_export(filepath=OUTPUT_BOTTOM, export_selected_objects=True, ascii_format=False)

bpy.ops.object.select_all(action='DESELECT')
top.select_set(True)
bpy.context.view_layer.objects.active = top
bpy.ops.wm.stl_export(filepath=OUTPUT_TOP, export_selected_objects=True, ascii_format=False)

bpy.ops.wm.save_as_mainfile(filepath=OUTPUT_BLEND)

print("\n" + "=" * 60)
d = bottom.dimensions
print(f"Bottom: {d.x:.2f} x {d.y:.2f} x {d.z:.2f}")
d = top.dimensions
print(f"Top: {d.x:.2f} x {d.y:.2f} x {d.z:.2f}")
print(f"\nExported:")
print(f"  {OUTPUT_BOTTOM}")
print(f"  {OUTPUT_TOP}")
print(f"  {OUTPUT_BLEND}")
print("Done!")
